# Copy this file to .env and fill in real values. .env is gitignored.
# In production, set these in the Vercel project's Environment Variables.

# Web3Forms access key for the contact form (public-safe; identifies the
# destination inbox, not a secret). Get one free at https://web3forms.com
PUBLIC_WEB3FORMS_ACCESS_KEY=your-web3forms-access-key

# Slug of the GitHub App backing the Keystatic CMS (used by keystatic.config.tsx).
PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=your-github-app-slug
